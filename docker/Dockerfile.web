FROM node:22-alpine AS build
WORKDIR /app
COPY src/PeruShopHub.Web/package*.json ./
RUN npm ci
COPY src/PeruShopHub.Web/ ./
RUN npx ng build --configuration=production

FROM nginx:alpine
COPY docker/nginx.conf /etc/nginx/nginx.conf
COPY --from=build /app/dist/PeruShopHub.Web/browser /usr/share/nginx/html
EXPOSE 80
