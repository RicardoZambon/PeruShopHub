FROM postgres:16-alpine

# Install dependencies for offsite sync, cron, and monitoring
RUN apk add --no-cache \
    bash \
    curl \
    aws-cli \
    gzip \
    redis

# Copy backup scripts
COPY scripts/backup/ /usr/local/bin/backup/
RUN chmod +x /usr/local/bin/backup/*.sh

# Copy monitoring scripts
COPY scripts/monitoring/ /usr/local/bin/monitoring/
RUN chmod +x /usr/local/bin/monitoring/*.sh

# Cron schedule:
#   3:00 AM daily — full backup with retention
#   4:00 AM Sunday — restore verification
#   Every hour — backup monitoring (25h threshold)
#   Every 5 min — system resource monitoring (disk, Redis, health)
COPY docker/backup-crontab /etc/crontabs/root

# Create backup volume mount point
RUN mkdir -p /backups

VOLUME ["/backups"]

CMD ["crond", "-f", "-l", "2"]
