{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.AspNetCore.Authentication": "Warning",
        "System": "Warning",
        "PeruShopHub": "Information"
      }
    },
    "RequestLogging": {
      "Enabled": true
    },
    "Filter": [
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "RequestPath like '/health%'"
        }
      }
    ],
    "Destructure": [
      {
        "Name": "ToMaximumDepth",
        "Args": { "maximumDestructuringDepth": 4 }
      },
      {
        "Name": "ToMaximumStringLength",
        "Args": { "maximumStringLength": 256 }
      }
    ]
  },
  "AllowedHosts": "*",
  "HealthChecks": {
    "EvaluationIntervalSeconds": 30
  },
  "RateLimiting": {
    "RequestsPerMinute": 100
  },
  "Jwt": {
    "Secret": "CHANGE-THIS-TO-A-SECURE-SECRET-AT-LEAST-32-CHARS",
    "Issuer": "PeruShopHub",
    "Audience": "PeruShopHub",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  }
}
