# PeruShopHub — Production Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# =============================================================================
# REQUIRED
# =============================================================================

# Your production domain (used by Nginx and Certbot)
DOMAIN=perushophub.com.br

# Docker image tag (commit SHA or "latest")
IMAGE_TAG=latest

# PostgreSQL password (generate: openssl rand -base64 32)
POSTGRES_PASSWORD=

# Redis password (generate: openssl rand -base64 32)
REDIS_PASSWORD=

# JWT signing secret — MINIMUM 32 characters (generate: openssl rand -base64 48)
JWT_SECRET=

# =============================================================================
# OPTIONAL — Integrations
# =============================================================================

# Sentry error tracking DSN
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Email service API key
# EMAIL_API_KEY=

# Mercado Livre OAuth credentials
# ML_APP_ID=
# ML_SECRET_KEY=

# =============================================================================
# OPTIONAL — Monitoring & Alerts
# =============================================================================

# Slack or Discord webhook URL for backup/health alerts
# ALERT_WEBHOOK=https://hooks.slack.com/services/...

# =============================================================================
# OPTIONAL — Offsite Backup (S3-compatible)
# =============================================================================

# OFFSITE_BUCKET=s3://perushophub-backups
# OFFSITE_ENDPOINT=https://s3.us-west-001.backblazeb2.com
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# =============================================================================
# OPTIONAL — Docker Registry
# =============================================================================

# GitHub repository owner (for ghcr.io image paths, defaults to ricardozambon)
# GITHUB_REPOSITORY_OWNER=ricardozambon
